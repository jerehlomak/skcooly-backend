generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SchoolSettings {
  id               String      @id @default(uuid())
  schoolId         String? // tenant isolation
  schoolName       String      @default("My School")
  arabicName       String?
  motto            String?
  tagline          String?
  phone            String?
  email            String?
  address          String?
  country          String?
  logoUrl          String?
  schoolTypeId     String? // foreign key to custom school type
  schoolType       SchoolType? @relation(fields: [schoolTypeId], references: [id])
  currentTerm      String?     @default("First Term")
  currentYear      String?     @default("2025/2026")
  currency         String?     @default("NGN")
  currencySymbol   String?     @default("₦")
  timezone         String?     @default("Africa/Lagos")
  rulesContent     String?     @db.Text
  formTeacherTitle String?     @default("Form Teacher")
  blockedFeatures  String[]    @default([])

  // Result Module settings
  resultSubjectPosition   Boolean @default(false)
  resultClassPosition     Boolean @default(true)
  resultShowBorder        Boolean @default(true)
  resultShowSignature     Boolean @default(true)
  resultShowNextTermFees  Boolean @default(false)
  resultAutomaticComments Boolean @default(false)
  parentResultAccessMode  String  @default("DIRECT") // DIRECT | PIN
  pinLifespan             String  @default("PER_TERM") // PER_TERM | PER_SESSION | PERMANENT
  parentTranscriptAccess  Boolean @default(false)

  issuedResultTypes String @default("BOTH") // CA_ONLY | EXAM_ONLY | BOTH
  caResultMode      String @default("NUMERIC") // NUMERIC | COMMENT
  examResultMode    String @default("NUMERIC") // NUMERIC | COMMENT
  resultConfig      Json?

  // Admission & Employment Settings
  admissionFormConfig        Json?
  employmentFormConfig       Json?
  admissionLetterTemplate    Json?
  employmentLetterTemplate   Json?
  parentAdmissionRequiresPin Boolean @default(true)

  // SMTP Settings
  smtpHost String?
  smtpPort Int?
  smtpUser String?
  smtpPass String?
  smtpFrom String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademicSession {
  id        String    @id @default(cuid())
  schoolId  String? // tenant isolation
  name      String // e.g. "2024/2025"
  startDate DateTime?
  endDate   DateTime?
  isCurrent Boolean   @default(false)

  classes  Class[]
  students StudentProfile[]

  isDeleted              Boolean                 @default(false)
  deletedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  AcademicTerm           AcademicTerm[]
  PromotionHistory       PromotionHistory[]
  studentTermEnrollments StudentTermEnrollment[]

  @@index([schoolId, isDeleted])
}

model Section {
  id        String  @id @default(cuid())
  schoolId  String? // tenant isolation
  name      String // e.g. "Primary", "Junior Secondary"
  shortCode String? // e.g. "PRI", "JSS"
  type      String? // e.g. "Primary", "Secondary"

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  classes Class[]

  @@index([schoolId, isDeleted])
}

model FeeParticular {
  id                 String   @id @default(uuid())
  schoolId           String? // tenant isolation
  label              String
  amount             Float    @default(0)
  isRequired         Boolean  @default(false)
  isFixed            Boolean  @default(false)
  // New assignment targeting fields
  assignToType       String   @default("ALL") // "ALL", "CLASS_LEVEL", "CLASS", "STUDENT"
  assignToLevels     String[] // e.g. ["JSS", "SSS"]
  assignToClassIds   String[] // e.g. ["class-id-1", "class-id-2"] 
  assignToStudentIds String[] // e.g. ["student-id-1"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  items FeeInvoiceItem[]

  @@index([schoolId, isDeleted])
}

model Transaction {
  id               String          @id @default(uuid())
  schoolId         String? // tenant isolation
  description      String
  category         String
  amount           Float
  type             TransType
  date             DateTime        @default(now())
  reference        String          @unique
  gateway          String          @default("Manual") // e.g., Cash, Flutterwave, Remita
  status           String          @default("Completed") // e.g., Pending, Completed, Failed
  feeInvoiceId     String?
  feeInvoice       FeeInvoice?     @relation(fields: [feeInvoiceId], references: [id])
  studentProfileId String?
  student          StudentProfile? @relation(fields: [studentProfileId], references: [id])
  ledgerEntries    StudentLedger[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  isDeleted Boolean        @default(false)
  deletedAt DateTime?
  terms     AcademicTerm[]

  @@index([schoolId, isDeleted])
}

model AcademicTerm {
  id         String    @id @default(uuid())
  schoolId   String // Tenant isolation
  sessionId  String // Relates to AcademicSession
  name       String // e.g. "First Term", "Second Term"
  startDate  DateTime?
  endDate    DateTime?
  isActive   Boolean   @default(false)
  isLocked   Boolean   @default(false)
  daysOpened Int?      @default(0)

  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  school  School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  Transaction            Transaction?            @relation(fields: [transactionId], references: [id])
  transactionId          String?
  studentTermEnrollments StudentTermEnrollment[]
  activityDeadlines      ActivityDeadline[]
  ActivityExemption      ActivityExemption[]

  @@unique([schoolId, sessionId, name])
  @@index([schoolId, isActive])
}

/// Configurable deadlines for school activities (score entry, fee entry, attendance, etc.)
model ActivityDeadline {
  id               String   @id @default(uuid())
  schoolId         String
  termId           String // Which term this deadline belongs to
  activity         String // e.g. SCORE_ENTRY | FEE_ENTRY | ATTENDANCE | CBT
  label            String? // Optional display label, e.g. "First Term Score Deadline"
  deadline         DateTime // Exact date + time when the activity locks
  warningLeadHours Int      @default(48) // Hours before deadline to show warning
  isActive         Boolean  @default(true)

  term AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, termId, activity])
  @@index([schoolId, isActive])
}

/// Allows specific users (teachers) to bypass term locks and activity deadlines
model ActivityExemption {
  id               String   @id @default(uuid())
  schoolId         String
  termId           String // Which term this exemption applies to
  userId           String // The staff member who is exempted
  activity         String // e.g. SCORE_ENTRY | ATTENDANCE | ALL
  classId          String? // Optional: restrict exemption to a specific class
  subjectId        String? // Optional: restrict exemption to a specific subject
  expiresAt        DateTime // When the exemption automatically ends
  grantedByAdminId String // Admin who granted it

  term    AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  class   Class?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  subject Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, termId, userId])
}

model StudentTermEnrollment {
  id               String   @id @default(uuid())
  schoolId         String
  studentProfileId String
  academicTermId   String
  classId          String
  sessionId        String
  createdAt        DateTime @default(now())

  student StudentProfile  @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  term    AcademicTerm    @relation(fields: [academicTermId], references: [id], onDelete: Cascade)
  class   Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, academicTermId])
  @@index([schoolId])
}

model FeeInvoice {
  id               String                  @id @default(uuid())
  schoolId         String? // tenant isolation
  studentProfileId String
  term             String
  year             String
  totalAmount      Float
  amountPaid       Float                   @default(0)
  status           String                  @default("Unpaid") // Unpaid, Partial, Paid
  dueDate          DateTime?
  lastPaymentDate  DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  student          StudentProfile          @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  items            FeeInvoiceItem[]
  installments     FeePaymentInstallment[]
  transactions     Transaction[]
  ledgerEntries    StudentLedger[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

model FeePaymentInstallment {
  id             String   @id @default(uuid())
  schoolId       String?
  feeInvoiceId   String
  amountPaid     Float
  paymentDate    DateTime @default(now())
  gateway        String   @default("Manual") // Stripe, Flutterwave, Remita, Manual
  transactionRef String?  @unique
  status         String   @default("Completed")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  feeInvoice    FeeInvoice      @relation(fields: [feeInvoiceId], references: [id], onDelete: Cascade)
  ledgerEntries StudentLedger[]

  @@index([schoolId, feeInvoiceId])
}

model GatewayLog {
  id        String   @id @default(uuid())
  schoolId  String?
  event     String
  payload   Json
  createdAt DateTime @default(now())

  @@index([schoolId])
}

model FeeInvoiceItem {
  id              String   @id @default(uuid())
  feeInvoiceId    String
  feeParticularId String?
  label           String
  amount          Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  feeInvoice    FeeInvoice     @relation(fields: [feeInvoiceId], references: [id], onDelete: Cascade)
  feeParticular FeeParticular? @relation(fields: [feeParticularId], references: [id], onDelete: SetNull)

  @@index([feeInvoiceId])
}

model StudentLedger {
  id               String   @id @default(uuid())
  schoolId         String?
  studentProfileId String
  date             DateTime @default(now())
  type             String // "DEBIT" (fee assigned) or "CREDIT" (payment made)
  category         String   @default("Fee Assignment") // e.g. "Payment", "Refund"
  description      String
  amount           Float
  balanceAfter     Float // computed snapshot of running balance after this entry
  feeInvoiceId     String?
  transactionId    String?
  installmentId    String?

  student     StudentProfile         @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  feeInvoice  FeeInvoice?            @relation(fields: [feeInvoiceId], references: [id], onDelete: SetNull)
  transaction Transaction?           @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  installment FeePaymentInstallment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([schoolId, studentProfileId])
  @@index([createdAt])
}

model SalarySlip {
  id               String         @id @default(uuid())
  schoolId         String? // tenant isolation
  teacherProfileId String
  payPeriod        String
  basic            Float
  allowance        Float          @default(0)
  deduction        Float          @default(0)
  netPay           Float
  status           String         @default("Pending") // Pending, Paid
  paymentReference String?
  paymentDate      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  teacher          TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

model BankAccount {
  id            String   @id @default(uuid())
  schoolId      String? // tenant isolation
  bankName      String
  accountNumber String
  branchAddress String?
  instructions  String?
  logoUrl       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

model ClassLevel {
  id        String   @id @default(uuid())
  schoolId  String?
  name      String
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model CustomRole {
  id              String   @id @default(uuid())
  schoolId        String? // tenant isolation
  name            String
  description     String?
  isSystemDefault Boolean  @default(false)
  users           User[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rolePermissions RolePermission[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

// ─── RBAC: Permission catalog + three-layer access control ──────────────────

enum DashboardType {
  STUDENT
  PARENT
  TEACHER
  STAFF
}

model Permission {
  id            String        @id @default(uuid())
  key           String        @unique // stable slug derived from route path, e.g. "results.record"
  label         String
  module        String // top-level grouping for the toggle UI, e.g. "Result Management"
  dashboardType DashboardType
  path          String?
  parentKey     String?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)

  schoolFeatures  SchoolFeature[]
  rolePermissions RolePermission[]

  @@index([dashboardType, module])
}

model SchoolDashboard {
  id            String        @id @default(uuid())
  schoolId      String
  dashboardType DashboardType
  enabled       Boolean       @default(true)
  updatedAt     DateTime      @updatedAt
  updatedById   String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, dashboardType])
}

model SchoolFeature {
  id           String   @id @default(uuid())
  schoolId     String
  permissionId String
  enabled      Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  updatedById  String?

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([schoolId, permissionId])
}

model RolePermission {
  id           String   @id @default(uuid())
  customRoleId String
  permissionId String
  createdAt    DateTime @default(now())

  customRole CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, permissionId])
}

model User {
  id                 String           @id @default(uuid())
  schoolId           String? // tenant isolation — links to School.id in central admin
  branchId           String? // null = school-scope user; set = branch-restricted user
  name               String
  email              String           @unique
  password           String
  role               Role             @default(STUDENT)
  customRoleId       String?
  customRole         CustomRole?      @relation(fields: [customRoleId], references: [id])
  recoveryKey        String?
  recoveryKeyExpires DateTime?
  // ─── Account Restriction ─────────────────────────────────────────────────
  isRestricted       Boolean          @default(false)
  restrictionReason  String?
  restrictedAt       DateTime?
  restrictedById     String? // The admin user who applied the restriction
  // ─────────────────────────────────────────────────────────────────────────
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  parentProfile      ParentProfile?
  studentProfile     StudentProfile?
  teacherProfile     TeacherProfile?
  tenantAuditLog     TenantAuditLog[]
  school             School?          @relation(fields: [schoolId], references: [id])
  branch             Branch?          @relation(fields: [branchId], references: [id])

  isDeleted         Boolean             @default(false)
  deletedAt         DateTime?
  ActivityExemption ActivityExemption[]

  @@index([schoolId, isDeleted])
  @@index([branchId])
}

model StudentProfile {
  id                    String                  @id @default(uuid())
  schoolId              String? // tenant isolation
  userId                String                  @unique
  enrollmentDate        DateTime                @default(now())
  admissionNo           String
  classLevel            String
  gender                String
  phone                 String?
  status                String                  @default("Active")
  address               String?
  admissionDate         DateTime                @default(now())
  bloodGroup            String?
  genotype              String?
  dateOfBirth           DateTime?
  publicId              String?                 @unique
  orphan                Boolean                 @default(false)
  parentProfileId       String?
  previousSchool        String?
  profilePicture        String?                 @db.Text
  religion              String?
  club                  String?
  classId               String? // specific class arm relation
  sessionId             String? // enrollment session
  subjectCategoryId     String? // links student to a subject category (for filtered result sheets)
  enrollments           Enrollment[]
  studentElectives      StudentElective[]
  feeInvoices           FeeInvoice[]
  attendanceRecords     AttendanceRecord[]
  studentResults        StudentResult[]
  studentReportComments StudentReportComment[]
  ledgerEntries         StudentLedger[]
  transactions          Transaction[]
  termEnrollments       StudentTermEnrollment[]
  parent                ParentProfile?          @relation(fields: [parentProfileId], references: [id])
  user                  User                    @relation(fields: [userId], references: [id])
  classArm              Class?                  @relation("ClassStudents", fields: [classId], references: [id])
  school                School?                 @relation(fields: [schoolId], references: [id])
  session               AcademicSession?        @relation(fields: [sessionId], references: [id])
  subjectCategory       SubjectCategory?        @relation("StudentSubjectCategory", fields: [subjectCategoryId], references: [id])

  isDeleted                  Boolean                      @default(false)
  deletedAt                  DateTime?
  CBTResult                  CBTResult[]
  AssignmentSubmission       AssignmentSubmission[]
  schoolPins                 SchoolPin[]
  StudentFeeAssignment       StudentFeeAssignment[]
  StudentTransportAssignment StudentTransportAssignment[]
  StudentWallet              StudentWallet?
  FinanceInvoice             FinanceInvoice[]
  PaymentTransaction         PaymentTransaction[]
  TransferSubmission         TransferSubmission[]
  FinanceReceipt             FinanceReceipt[]
  Scholarship                Scholarship[]
  promotionHistory           PromotionHistory[]
  LegacyResult               LegacyResult[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId, isDeleted])
  @@index([schoolId, classId])
}

model TeacherProfile {
  id                 String         @id @default(uuid())
  schoolId           String? // tenant isolation
  userId             String         @unique
  publicId           String?        @unique
  department         String?
  employeeId         String
  gender             String
  hireDate           DateTime       @default(now())
  phone              String?
  status             String         @default("Active")
  address            String?
  dateOfBirth        DateTime?
  qualification      String?
  salary             Float?
  bankName           String?
  accountNumber      String?
  accountName        String?
  subjectsTaught     String?
  staffType          String?        @default("TEACHER") // TEACHER, CLASS_TEACHER, ADMIN, OTHER
  canEnterPastScores Boolean        @default(false)
  photoUrl           String?
  courses            Course[]
  salarySlips        SalarySlip[]
  assignedSubjects   Subject[]      @relation("SubjectTeacher")
  formClasses        Class[]        @relation("FormTeacher")
  classSubjects      ClassSubject[] @relation("ClassSubjectTeacher")
  user               User           @relation(fields: [userId], references: [id])
  school             School?        @relation(fields: [schoolId], references: [id])

  isDeleted       Boolean           @default(false)
  deletedAt       DateTime?
  QuestionBank    QuestionBank[]
  Assignment      Assignment[]
  LessonResource  LessonResource[]
  StaffAttendance StaffAttendance[]

  // Payroll relations
  payrollSettings PayrollSetting[] @relation("StaffPayrollSettings")
  staffLoans      StaffLoan[]      @relation("StaffLoans")
  pensionEntries  PensionLedger[]  @relation("StaffPension")
  payrollRunItems PayrollRunItem[] @relation("StaffPayrollRunItems")

  @@unique([schoolId, employeeId])
  @@index([schoolId, isDeleted])
}

model ParentProfile {
  id               String           @id @default(uuid())
  schoolId         String? // tenant isolation
  userId           String           @unique
  parentId         String
  phone            String
  occupation       String?
  address          String?
  fatherEducation  String?
  fatherName       String?
  fatherNationalId String?
  fatherOccupation String?
  fatherPhone      String?
  motherEducation  String?
  motherName       String?
  motherNationalId String?
  motherOccupation String?
  motherPhone      String?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  students         StudentProfile[]
  school           School?          @relation(fields: [schoolId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([schoolId, parentId])
  @@index([schoolId, isDeleted])
}

model Class {
  id                     String                  @id @default(uuid())
  schoolId               String? // tenant isolation
  sessionId              String? // Reference to AcademicSession
  name                   String
  level                  String
  section                String?
  sectionId              String?
  order                  Int                     @default(0)
  status                 String                  @default("Active")
  formTeacherId          String?
  nextTermFee            String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  session                AcademicSession?        @relation(fields: [sessionId], references: [id])
  formTeacher            TeacherProfile?         @relation("FormTeacher", fields: [formTeacherId], references: [id])
  sectionRel             Section?                @relation(fields: [sectionId], references: [id])
  subjects               ClassSubject[]
  legacyResults          LegacyResult[]
  students               StudentProfile[]        @relation("ClassStudents")
  attendanceRecords      AttendanceRecord[]      @relation("ClassAttendance")
  exams                  Exam[]
  assignments            Assignment[]
  lessonResources        LessonResource[]
  promotionHistoryFrom   PromotionHistory[]      @relation("FromClass")
  promotionHistoryTo     PromotionHistory[]      @relation("ToClass")
  studentTermEnrollments StudentTermEnrollment[]

  isDeleted         Boolean             @default(false)
  deletedAt         DateTime?
  ActivityExemption ActivityExemption[]

  @@index([schoolId, isDeleted])
}

model SubjectCategory {
  id       String  @id @default(cuid())
  schoolId String?
  name     String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subjects Subject[]
  students StudentProfile[] @relation("StudentSubjectCategory")

  @@index([schoolId, isDeleted])
}

model Subject {
  id               String            @id @default(uuid())
  schoolId         String? // tenant isolation
  name             String
  code             String?
  categoryId       String?
  type             String?
  description      String?
  status           String            @default("Active")
  teacherId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  classes          ClassSubject[]
  enrollments      Enrollment[]
  studentElectives StudentElective[]
  studentResults   StudentResult[]
  teacher          TeacherProfile?   @relation("SubjectTeacher", fields: [teacherId], references: [id])
  category         SubjectCategory?  @relation(fields: [categoryId], references: [id])

  isDeleted         Boolean             @default(false)
  deletedAt         DateTime?
  QuestionBank      QuestionBank[]
  Exam              Exam[]
  Assignment        Assignment[]
  LessonResource    LessonResource[]
  ActivityExemption ActivityExemption[]

  @@index([schoolId, isDeleted])
}

model ClassSubject {
  id         String          @id @default(uuid())
  classId    String
  categoryId String?
  subjectId  String
  teacherId  String? // NEW: specific teacher handling this subject in this class
  class      Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject    Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher    TeacherProfile? @relation("ClassSubjectTeacher", fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
}

model Course {
  id          String          @id @default(uuid())
  schoolId    String? // tenant isolation
  name        String
  description String?
  teacherId   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  teacher     TeacherProfile? @relation(fields: [teacherId], references: [id])
  enrollments Enrollment[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

model Enrollment {
  id               String         @id @default(uuid())
  studentProfileId String
  courseId         String?
  enrolledAt       DateTime       @default(now())
  subjectId        String?
  course           Course?        @relation(fields: [courseId], references: [id])
  student          StudentProfile @relation(fields: [studentProfileId], references: [id])
  subject          Subject?       @relation(fields: [subjectId], references: [id])
}

model StudentElective {
  id               String   @id @default(uuid())
  schoolId         String
  studentProfileId String
  subjectId        String
  createdAt        DateTime @default(now())

  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, subjectId])
  @@index([schoolId])
}

// Daily attendance records for students
model AttendanceRecord {
  id               String           @id @default(uuid())
  schoolId         String? // tenant isolation
  studentProfileId String
  date             String // ISO date string: "2026-03-04"
  classId          String // Specific class arm ID (e.g. JSS1A)
  status           AttendanceStatus @default(PRESENT)
  note             String?
  markedBy         String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  student          StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  class            Class            @relation("ClassAttendance", fields: [classId], references: [id])

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([studentProfileId, date])
  @@index([schoolId, isDeleted])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// Weekly timetable entries persisted per class
model TimetableEntry {
  id          String   @id @default(uuid())
  schoolId    String? // tenant isolation
  classId     String
  day         String
  period      String
  subject     String
  teacherName String
  teacherId   String?
  color       String   @default("bg-blue-100 text-blue-700")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([classId, day, period])
  @@index([schoolId, isDeleted])
}

// Configuration for generating periods per class
model TimetableSetup {
  id              String   @id @default(uuid())
  classId         String   @unique
  numOfPeriods    Int      @default(8)
  periodDuration  Int      @default(45) // in minutes
  startTime       String   @default("08:00 AM")
  shortBreakStart String?  @default("10:15 AM")
  shortBreakEnd   String?  @default("10:30 AM")
  longBreakStart  String?  @default("12:00 PM")
  longBreakEnd    String?  @default("12:30 PM")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Internal Messaging (staff-to-staff or broadcast)
model Message {
  id             String   @id @default(uuid())
  schoolId       String? // tenant isolation
  senderId       String
  senderName     String
  recipientGroup String // e.g. 'all', 'teachers', 'students', 'parents', or a userId
  subject        String?
  body           String   @db.Text
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

// Bulk SMS Log
model SmsLog {
  id             String    @id @default(uuid())
  schoolId       String? // tenant isolation
  category       String
  message        String    @db.Text
  recipientGroup String
  recipientCount Int
  sentBy         String // user name
  status         SmsStatus @default(DELIVERED)
  createdAt      DateTime  @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

enum SmsStatus {
  DELIVERED
  PARTIAL
  FAILED
}

model SchoolType {
  id             String   @id @default(uuid())
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // optional default flag for new schools
  isDefault      Boolean  @default(false)
  defaultClasses Json?    @default("[]")

  // School ownership — null means platform-level (legacy), set means school-specific
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // reverse relation (optional)
  settings SchoolSettings[]

  @@unique([schoolId, name])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
  SCHOOL_SUPER_ADMIN // school-wide admin, can switch branch context without logging out
  SCHOOL_ADMIN // school-level admin
  BRANCH_ADMIN // restricted to own branch only
  BRANCH_STAFF // restricted to own branch only
}

enum TransType {
  income
  expense
}

// ─── CENTRAL ADMIN (Platform-level SaaS management) ──────────────────────────

enum CentralAdminRole {
  SUPER_ADMIN
  SUPPORT
  STAFF // company-level staff with granular permissions
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DELETED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Central admin users (platform owner & support staff)
model CentralAdmin {
  id                   String                @id @default(uuid())
  name                 String
  email                String                @unique
  password             String
  role                 CentralAdminRole      @default(SUPPORT)
  isActive             Boolean               @default(true)
  lastLogin            DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  otpToken             String? // For 2FA
  otpExpires           DateTime? // For 2FA
  permissions          Json? // granular permission list e.g. ["manage_schools","generate_pins"]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  auditLogs            AuditLog[]
  announcements        Announcement[]
  ticketReplies        TicketReply[]
  pinBatches           SchoolPinBatch[]
  platformTx           PlatformTransaction[]
}

// Subscription plans available on the platform
model SubscriptionPlan {
  id            String               @id @default(uuid())
  name          String               @unique // e.g., Basic, Pro, Enterprise
  description   String?
  monthlyPrice  Float                @default(0)
  yearlyPrice   Float                @default(0)
  priceLabel    String? // Custom label e.g. "Contact Us", "Negotiable", overrides price display
  maxStudents   Int                  @default(100)
  maxTeachers   Int                  @default(10)
  maxClasses    Int                  @default(10)
  maxBranches   Int                  @default(1)
  storageLimit  Int                  @default(1024) // in MB
  features      Json                 @default("[]") // array of feature keys enabled
  isActive      Boolean              @default(true)
  trialDays     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  schools       School[]
  subscriptions SchoolSubscription[]
  schoolLeads   SchoolLead[]
}

// Leads / Inquiries from the website
model SchoolLead {
  id              String  @id @default(uuid())
  schoolName      String
  contactPerson   String
  phoneNumber     String
  emailAddress    String
  stateLga        String?
  preferredPlanId String?
  notes           String?
  status          String  @default("NEW") // NEW, CONTACTED, CONVERTED, REJECTED

  preferredPlan SubscriptionPlan? @relation(fields: [preferredPlanId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A group of schools (multi-branch organization)
model SchoolGroup {
  id        String       @id @default(uuid())
  name      String
  email     String?      @unique
  phone     String?
  address   String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  schools   School[]
  admins    GroupAdmin[]
}

// Owner/Administrator of a SchoolGroup
model GroupAdmin {
  id        String      @id @default(uuid())
  groupId   String
  name      String
  email     String      @unique
  password  String
  role      String      @default("GROUP_ADMIN")
  lastLogin DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  group     SchoolGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// Tenant schools registered on the platform
model School {
  notifications              Notification[]
  id                         String                       @id @default(uuid())
  schoolCode                 String?                      @unique // e.g. SKL-A1B2C3 — required for user login
  name                       String
  email                      String                       @unique
  phone                      String?
  address                    String?
  country                    String?                      @default("Nigeria")
  logoUrl                    String?
  status                     SchoolStatus                 @default(PENDING)
  planId                     String?
  studentCount               Int                          @default(0)
  teacherCount               Int                          @default(0)
  adminEmail                 String? // primary school admin login email
  dbSchemaKey                String? // namespace/tenant key if needed
  legacyResults              LegacyResult[]
  suspendedAt                DateTime?
  suspendReason              String?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  groupId                    String?
  group                      SchoolGroup?                 @relation(fields: [groupId], references: [id])
  parentId                   String? // Link to main school if this is a branch
  parent                     School?                      @relation("MainSchoolToBranch", fields: [parentId], references: [id])
  branchSchools              School[]                     @relation("MainSchoolToBranch")
  plan                       SubscriptionPlan?            @relation(fields: [planId], references: [id])
  subscription               SchoolSubscription?
  featureFlags               FeatureFlag[]
  tickets                    SupportTicket[]
  auditLogs                  AuditLog[]
  usageMetrics               UsageMetric[]
  invoices                   Invoice[]
  payments                   Payment[]
  billingEvents              BillingEvent[]
  tenantAuditLogs            TenantAuditLog[]             @relation("TenantAuditLogs")
  users                      User[]
  schoolTypes                SchoolType[]
  students                   StudentProfile[]
  teachers                   TeacherProfile[]
  parents                    ParentProfile[]
  branches                   Branch[] // Phase 1: one school → many branches
  pinBatches                 SchoolPinBatch[]
  schoolPins                 SchoolPin[]
  platformTx                 PlatformTransaction[]
  wallet                     SchoolWallet? // Phase 6: school wallet
  billingProfile             SchoolBillingProfile? // Phase 5: billing contact
  walletTx                   WalletTransaction[] // Phase 6: wallet transactions
  conversations              SchoolConversation[] // Phase 7: messaging
  FinanceSettings            FinanceSettings?
  FeeDefinition              FeeDefinition[]
  StudentFeeAssignment       StudentFeeAssignment[]
  TransportRoute             TransportRoute[]
  StudentTransportAssignment StudentTransportAssignment[]
  StudentWallet              StudentWallet[]
  StudentWalletTransaction   StudentWalletTransaction[]
  FinanceInvoice             FinanceInvoice[]
  SchoolPaymentSettings      SchoolPaymentSettings?
  SchoolBankAccount          SchoolBankAccount[]
  PaymentTransaction         PaymentTransaction[]
  PaymentAllocation          PaymentAllocation[]
  TransferSubmission         TransferSubmission[]
  FinanceReceipt             FinanceReceipt[]
  FinanceNotificationLog     FinanceNotificationLog[]
  QRCode                     QRCode[]
  StaffAttendance            StaffAttendance[]
  AttendanceScanLog          AttendanceScanLog[]
  AttendanceSettings         AttendanceSettings?
  ScannerDevice              ScannerDevice[]
  Scholarship                Scholarship[]
  AcademicTerm               AcademicTerm[]
  applications               Application[]
  schoolDashboards           SchoolDashboard[]
  schoolFeatures             SchoolFeature[]
}

// ─── BRANCHES (Phase 1) ──────────────────────────────────────────────────────

// A branch belongs to exactly one school. Branch users are restricted to their branch.
// school_super_admin has branchId = null (school-wide scope) and can switch branch context.
model Branch {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  code      String?
  address   String?
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED, INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school                   School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users                    User[]
  FeeDefinition            FeeDefinition[]
  TransportRoute           TransportRoute[]
  StudentWalletTransaction StudentWalletTransaction[]
  FinanceInvoice           FinanceInvoice[]
  StudentWallet            StudentWallet[]
  SchoolBankAccount        SchoolBankAccount[]
  PaymentTransaction       PaymentTransaction[]
  TransferSubmission       TransferSubmission[]
  FinanceReceipt           FinanceReceipt[]

  @@index([schoolId])
}

// Active subscription for each school
model SchoolSubscription {
  id              String             @id @default(uuid())
  schoolId        String             @unique
  planId          String
  status          SubscriptionStatus @default(ACTIVE)
  billingCycle    BillingCycle       @default(MONTHLY)
  startDate       DateTime           @default(now())
  endDate         DateTime?
  trialEnd        DateTime?
  nextBillingDate DateTime?
  cancelledAt     DateTime?
  suspendedAt     DateTime?
  isActive        Boolean            @default(true)
  autoRenew       Boolean            @default(true)
  amountPaid      Float              @default(0)
  currency        String             @default("USD")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  school          School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan   @relation(fields: [planId], references: [id])
  invoices        Invoice[]
}

// Per-school feature toggles
model FeatureFlag {
  id        String   @id @default(uuid())
  schoolId  String
  feature   String // e.g., "timetable", "sms", "finance", "analytics"
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, feature])
}

// Global announcements broadcast to all schools
model Announcement {
  id          String       @id @default(uuid())
  title       String
  body        String       @db.Text
  type        String       @default("INFO") // INFO, WARNING, MAINTENANCE
  targetGroup String       @default("ALL") // ALL, BASIC, PRO, ENTERPRISE
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  adminId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  admin       CentralAdmin @relation(fields: [adminId], references: [id])
}

// Support tickets submitted by school admins
model SupportTicket {
  id          String         @id @default(uuid())
  schoolId    String
  subject     String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  submittedBy String // school admin email
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  school      School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  replies     TicketReply[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

// Replies to support tickets
model TicketReply {
  id        String        @id @default(uuid())
  ticketId  String
  adminId   String
  message   String        @db.Text
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  admin     CentralAdmin  @relation(fields: [adminId], references: [id])
}

// Audit log for every central admin action
model AuditLog {
  id         String        @id @default(uuid())
  adminId    String?
  action     String // e.g., "CREATE_SCHOOL", "SUSPEND_SCHOOL", "UPDATE_PLAN"
  entityType String? // e.g., "School", "Plan", "Feature"
  entityId   String? // ID of the affected record
  metadata   Json? // extra context (old values, new values, etc.)
  ipAddress  String?
  createdAt  DateTime      @default(now())
  admin      CentralAdmin? @relation(fields: [adminId], references: [id])
  school     School?       @relation(fields: [entityId], references: [id])

  @@index([adminId, createdAt(sort: Desc)])
}

// Tenant-level audit log for actions within a school
model TenantAuditLog {
  id         String   @id @default(uuid())
  schoolId   String
  userId     String? // user who performed the action
  action     String // e.g., "DELETE_STUDENT", "UPDATE_RESULT"
  entityType String // e.g., "StudentProfile", "StudentResult"
  entityId   String? // ID of the affected record
  metadata   Json? // old values/new values
  ipAddress  String?
  createdAt  DateTime @default(now())

  school School @relation("TenantAuditLogs", fields: [schoolId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([schoolId, userId])
}

// ─── ASSESSMENT & RESULTS ──────────────────────────────────────────────────

// Stores the grading weights defined by Admin for each School Category
model AssessmentStructure {
  id         String   @id @default(uuid())
  schoolId   String? // tenant isolation
  category   String // e.g., 'Nursery', 'Primary', 'JSS', 'SSS', 'Arabic'
  classId    String? // Optional override per class
  resultType String   @default("SCORE_BASED") // SCORE_BASED | COMMENT_BASED
  parts      Json // e.g. [{"id": "1", "name": "1st CA", "weight": 20}, {"id": "2", "name": "Exam", "weight": 60}]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Remove strict uniqueness to allow multiple class overrides in the same category
  @@index([schoolId, category])
  @@index([schoolId, isDeleted])
}

// Stores individual subject scores per student per term
model StudentResult {
  id               String   @id @default(uuid())
  schoolId         String? // tenant isolation
  studentProfileId String
  subjectId        String
  classId          String
  term             String // e.g. "First Term"
  academicYear     String // e.g. "2025/2026"
  category         String // e.g. "JSS"
  scores           Json // e.g. {"1st CA": 18, "Exam": 50}
  totalScore       Float    @default(0)
  grade            String?
  subjectPosition  Int?
  teacherId        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([studentProfileId, subjectId, term, academicYear])
  @@index([schoolId, isDeleted])
}

// Stores legacy uploaded PDFs for historical results
model LegacyResult {
  id           String   @id @default(uuid())
  schoolId     String
  classId      String
  studentId    String?
  academicYear String
  term         String
  sessionName  String?
  fileUrl      String
  uploadedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  class   Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  school  School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student StudentProfile? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, classId, academicYear])
  @@index([schoolId, studentId])
}

// Stores the computed overall results for a student per term
model StudentTermResult {
  id               String   @id @default(uuid())
  schoolId         String
  studentProfileId String
  classId          String
  term             String
  academicYear     String
  totalScore       Float    @default(0)
  average          Float    @default(0)
  position         Int?
  status           String   @default("PENDING") // PASS, FAIL
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentProfileId, term, academicYear])
  @@index([schoolId, classId])
}

model ResultTemplate {
  id                String   @id @default(uuid())
  schoolId          String
  name              String // e.g. "Template 1", "Original"
  isActive          Boolean  @default(false)
  resultType        String   @default("SCORE_BASED") // "SCORE_BASED", "COMMENT_BASED", "TRANSCRIPT"
  config            Json // Stores all the toggles, colors, etc.
  assignedSectionId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model CommentRule {
  id         String   @id @default(uuid())
  schoolId   String
  category   String? // e.g. "Primary"
  classId    String? // Optional override per class
  role       String // "Class Teacher", "Head Teacher", "Principal"
  resultType String   @default("EXAM") // EXAM, CA, COMMENT_BASED
  minScore   Float
  maxScore   Float
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId, category])
  @@index([schoolId, classId])
}

model SharingHistory {
  id               String   @id @default(uuid())
  schoolId         String
  studentProfileId String
  term             String
  academicYear     String
  channel          String // "WhatsApp", "Email", "SMS"
  recipient        String // Email or Phone
  status           String // "Sent", "Failed", "Pending"
  sentAt           DateTime @default(now())

  @@index([schoolId, studentProfileId])
}

// ─── BILLING & SUBSCRIPTIONS ───────────────────────────────────────────────

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  SENT
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  FAILED
  CANCELLED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  PAYSTACK
  REMITA
  FLUTTERWAVE
  STRIPE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// Track platform usage per school
model UsageMetric {
  id               String   @id @default(uuid())
  schoolId         String
  periodStart      DateTime
  periodEnd        DateTime
  numberOfStudents Int      @default(0)
  numberOfTeachers Int      @default(0)
  numberOfBranches Int      @default(0)
  storageUsage     Int      @default(0) // in MB
  apiRequests      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, periodStart, periodEnd])
  @@index([schoolId, isDeleted])
}

// Invoices issued by platform to schools
model Invoice {
  id               String        @id @default(uuid())
  schoolId         String
  subscriptionId   String?
  invoiceNumber    String        @unique
  title            String        @default("Platform Invoice")
  description      String?       @db.Text
  amount           Float
  currency         String        @default("NGN")
  taxAmount        Float         @default(0)
  discountAmount   Float         @default(0)
  totalAmount      Float
  amountPaid       Float         @default(0)
  amountDue        Float?
  dueDate          DateTime
  issuedAt         DateTime      @default(now())
  sentAt           DateTime?
  status           InvoiceStatus @default(DRAFT)
  createdByAdminId String?
  paidFromWallet   Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscription SchoolSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  payments     Payment[]
  reminders    InvoiceReminder[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
  @@index([status])
}

// Line items for invoices
model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  itemName    String
  description String?
  quantity    Int     @default(1)
  unitPrice   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// Invoice payment reminders
model InvoiceReminder {
  id             String   @id @default(uuid())
  invoiceId      String
  reminderType   String   @default("MANUAL") // MANUAL | DUE_SOON | OVERDUE
  message        String?  @db.Text
  sentByAdminId  String?
  sentAt         DateTime @default(now())
  deliveryStatus String   @default("SENT") // SENT | FAILED | PENDING
  createdAt      DateTime @default(now())
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── SCHOOL WALLET SYSTEM (Phase 6) ──────────────────────────────────────────

model SchoolWallet {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  balance   Float    @default(0)
  currency  String   @default("NGN")
  status    String   @default("ACTIVE") // ACTIVE | FROZEN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([schoolId])
}

model WalletTransaction {
  id                    String   @id @default(uuid())
  walletId              String
  schoolId              String
  type                  String // CREDIT | DEBIT
  source                String // TOPUP | INVOICE_PAYMENT | ADJUSTMENT | REFUND
  sourceId              String? // invoiceId if source = INVOICE_PAYMENT
  amount                Float
  balanceBefore         Float
  balanceAfter          Float
  reference             String   @unique
  description           String?
  createdByAdminId      String?
  createdBySchoolUserId String?
  createdAt             DateTime @default(now())

  wallet SchoolWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  school School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([schoolId])
}

// ─── SCHOOL BILLING PROFILE (Phase 5 gap) ────────────────────────────────────

model SchoolBillingProfile {
  id                 String   @id @default(uuid())
  schoolId           String   @unique
  billingEmail       String?
  billingPhone       String?
  billingContactName String?
  billingAddress     String?
  taxId              String?
  preferredCurrency  String   @default("NGN")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

// Payments for invoices
model Payment {
  id            String        @id @default(uuid())
  invoiceId     String
  schoolId      String
  paymentMethod PaymentMethod
  amount        Float
  currency      String        @default("USD")
  transactionId String?       @unique
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

// Coupons for discounts
model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  expiresAt     DateTime?
  usageLimit    Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─── MESSAGING CENTER (Phase 7) ──────────────────────────────────────────────

model SchoolConversation {
  id            String   @id @default(uuid())
  schoolId      String
  subject       String   @default("General Inquiry")
  lastMessageAt DateTime @default(now())
  isClosed      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school   School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  messages SchoolMessage[]

  @@index([schoolId])
  @@index([lastMessageAt(sort: Desc)])
}

model SchoolMessage {
  id             String    @id @default(uuid())
  conversationId String
  senderType     String // "ADMIN" | "SCHOOL"
  senderId       String // CentralAdmin.id or User.id
  senderName     String // snapshot for display
  content        String    @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation SchoolConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt(sort: Asc)])
}

// Lifecycle events
model BillingEvent {
  id          String   @id @default(uuid())
  schoolId    String
  eventType   String // e.g., 'SUBSCRIPTION_CREATED', 'PAYMENT_FAILED', 'INVOICE_GENERATED'
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([schoolId, isDeleted])
}

// ─── REPORT CARD TEMPLATE SYSTEM ────────────────────────────────────────────

// Stores the full JSON layout configuration for a report card template
model ReportTemplate {
  id               String                    @id @default(uuid())
  schoolId         String
  name             String // e.g. "JSS Template"
  type             String                    @default("EXAM") // e.g. "CA", "EXAM", "CUMULATIVE", "TRANSCRIPT"
  category         String? // e.g. "JSS", "SSS", "Nursery"
  config           Json // full layout/section/design config as JSON
  isDefault        Boolean                   @default(false)
  isDeleted        Boolean                   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  classAssignments TemplateClassAssignment[]

  @@index([schoolId, isDeleted])
}

// Links a template to a specific class arm for a specific result type
model TemplateClassAssignment {
  id         String         @id @default(uuid())
  schoolId   String
  templateId String
  classId    String
  type       String         @default("EXAM")
  template   ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, type])
}

// Persistent grading scale per school section
model GradingScale {
  id             String   @id @default(uuid())
  schoolId       String
  category       String?  @default("ALL") // Primary, JSS, SSS, ALL
  classId        String? // Optional override per class
  type           String   @default("SUBJECT") // Deprecated somewhat, keeping for backwards compatibility
  resultType     String   @default("SCORE_BASED") // SCORE_BASED | COMMENT_BASED
  assessmentType String   @default("EXAM") // EXAM | CA
  passMark       Float    @default(40)
  grades         Json // [{grade, minScore, maxScore, remark, status}]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([schoolId, category])
  @@index([schoolId, classId])
}

// Per-student, per-term comments from teacher / head teacher / principal
model StudentReportComment {
  id                String         @id @default(uuid())
  schoolId          String
  studentProfileId  String
  term              String
  academicYear      String
  teacherComment    String?        @db.Text
  headComment       String?        @db.Text
  principalComment  String?        @db.Text
  narrativeComments Json?
  nextTermBegins    String?
  promotedTo        String?
  present           Int?
  absent            Int?
  total             Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  student           StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentProfileId, term, academicYear])
  @@index([schoolId])
}

// ─── NEW RESULT MODULE MODELS (PHASE 1) ───────────────────────────────────

// Tracks score entry state per class/subject/term (Not Started, In Progress, Submitted)
model SubjectEntryStatus {
  id           String    @id @default(uuid())
  schoolId     String
  classId      String
  subjectId    String
  term         String
  academicYear String
  entryType    String    @default("NUMERIC") // NUMERIC, COMMENT, TRAIT
  status       String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, SUBMITTED
  submittedAt  DateTime?
  submittedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([schoolId, classId, subjectId, term, academicYear])
  @@index([schoolId, classId])
}

// Tracks whether results are released for a class/term
model ResultReleaseStatus {
  id           String    @id @default(uuid())
  schoolId     String
  classId      String
  term         String
  academicYear String
  isReleased   Boolean   @default(false)
  resultFormat String    @default("SCORE_BASED") // SCORE_BASED | COMMENT_BASED
  visibleTypes Json?
  releasedAt   DateTime?
  releasedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([schoolId, classId, term, academicYear])
  @@index([schoolId])
}

// Stores affective/psychomotor trait scores per student/term
model TraitRating {
  id               String   @id @default(uuid())
  schoolId         String
  studentProfileId String
  classId          String
  term             String
  academicYear     String
  domain           String // AFFECTIVE, PSYCHOMOTOR
  ratings          Json // e.g. {"Neatness": "A", "Punctuality": "B"}
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([schoolId, studentProfileId, domain, term, academicYear])
  @@index([schoolId, classId])
}

// Defines available traits and rating scales per domain
model TraitConfiguration {
  id          String   @id @default(uuid())
  schoolId    String
  domain      String // AFFECTIVE, PSYCHOMOTOR
  category    String   @default("ALL") // Nursery, Primary, Secondary, etc.
  classId     String? // Optional override per class
  traits      String[] // ["Neatness", "Punctuality", ...]
  ratingScale Json // [{"rating": "A", "description": "Excellent"}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, domain, category])
  @@index([schoolId, classId])
}

// ─── LMS & CBT (Phase 1 Expansion) ───────────────────────────────────────────

model QuestionBank {
  id            String   @id @default(uuid())
  schoolId      String
  subjectId     String
  teacherId     String?
  questionText  String   @db.Text
  type          String // e.g., "MULTIPLE_CHOICE", "TRUE_FALSE", "ESSAY"
  options       Json? // Array of options
  correctAnswer String?
  marks         Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subject       Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       TeacherProfile? @relation(fields: [teacherId], references: [id])
  examQuestions ExamQuestion[]

  @@index([schoolId])
}

model Exam {
  id              String    @id @default(uuid())
  schoolId        String
  classId         String
  subjectId       String
  title           String
  instructions    String?   @db.Text
  durationMinutes Int       @default(60)
  startTime       DateTime?
  endTime         DateTime?
  passingMarks    Int       @default(40)
  status          String    @default("DRAFT") // DRAFT, PUBLISHED, CONCLUDED
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  examQuestions ExamQuestion[]
  cbtResults    CBTResult[]

  @@index([schoolId, classId])
}

model ExamQuestion {
  id         String @id @default(uuid())
  examId     String
  questionId String
  position   Int    @default(0) // order of questions

  exam     Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  question QuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
}

model CBTResult {
  id               String   @id @default(uuid())
  examId           String
  studentProfileId String
  answers          Json? // Student's submitted answers
  totalScore       Float    @default(0)
  submittedAt      DateTime @default(now())

  exam    Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([examId, studentProfileId])
}

model Assignment {
  id          String    @id @default(uuid())
  schoolId    String
  classId     String
  subjectId   String
  teacherId   String?
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  maxScore    Float     @default(100)
  attachments Json? // Uploaded files info
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  class       Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     TeacherProfile?        @relation(fields: [teacherId], references: [id])
  submissions AssignmentSubmission[]

  @@index([schoolId, classId])
}

model AssignmentSubmission {
  id               String   @id @default(uuid())
  assignmentId     String
  studentProfileId String
  attachedFiles    Json? // Student's uploads
  teacherFeedback  String?  @db.Text
  score            Float?
  submittedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assignment Assignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentProfileId])
}

model LessonResource {
  id          String   @id @default(uuid())
  schoolId    String
  classId     String
  subjectId   String
  teacherId   String?
  title       String
  type        String // e.g., "PDF", "VIDEO", "LINK"
  fileUrl     String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class   Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher TeacherProfile? @relation(fields: [teacherId], references: [id])

  @@index([schoolId, classId])
}

// ─── PIN MANAGEMENT SYSTEM (PHASE 3) ───────────────────────────────────────

model SchoolPinBatch {
  id          String   @id @default(uuid())
  batchNumber String   @unique // e.g. BATCH-2025-001
  pinType     String   @default("RESULT_CHECKING") // RESULT_CHECKING, ADMISSION_APPLICATION, EMPLOYMENT
  schoolId    String? // If pre-assigned to a school
  quantity    Int
  pricePerPin Float    @default(0)
  currency    String   @default("NGN")
  status      String   @default("ACTIVE") // ACTIVE, DEPLETED, CANCELLED
  maxUsage    Int      @default(5)
  validityDays Int?    // Null means no time limit once activated
  adminId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  admin  CentralAdmin? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  pins   SchoolPin[]
}

model SchoolPin {
  id           String    @id @default(uuid())
  pinCode      String    @unique
  serialNumber String    @unique
  pinType      String    @default("RESULT_CHECKING") // RESULT_CHECKING, ADMISSION_APPLICATION, EMPLOYMENT
  batchId      String
  schoolId     String?
  studentId    String?
  usageCount       Int       @default(0)
  maxUsage         Int       @default(5)
  status           String    @default("ACTIVE") // ACTIVE, USED, EXPIRED
  expiresAt        DateTime?
  activatedForTerm String?   // Term the PIN is locked to
  activatedForYear String?   // Session/Year the PIN is locked to
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  batch       SchoolPinBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  school      School?         @relation(fields: [schoolId], references: [id])
  student     StudentProfile? @relation(fields: [studentId], references: [id])
  usageLogs   PinUsageLog[]
  application Application?

  @@index([batchId])
  @@index([schoolId])
}

model PinUsageLog {
  id               String   @id @default(uuid())
  pinId            String
  usageContext     String // e.g. "RESULT_VERIFICATION", "ADMISSION_FORM"
  action           String // e.g. "VIEWED_TERM_RESULT"
  metadata         Json? // e.g. { term: "First Term", year: "2024/2025" }
  usedByIdentifier String? // e.g. student ID or Admission No
  createdAt        DateTime @default(now())

  pin SchoolPin @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@index([pinId])
}

// ─── PLATFORM COMPANY LEDGER (PHASE 3) ───────────────────────────────────────
model PlatformTransaction {
  id          String   @id @default(uuid())
  reference   String   @unique
  type        String // INCOME, EXPENSE
  category    String // SUBSCRIPTION, PIN_SALES, HOSTING, MARKETING, SALARY, OTHER
  amount      Float
  currency    String   @default("USD") // Central Admin base currency
  description String?
  schoolId    String? // Optional relation if it came from a school
  adminId     String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School?       @relation(fields: [schoolId], references: [id])
  admin  CentralAdmin? @relation(fields: [adminId], references: [id])

  @@index([type])
  @@index([schoolId])
}

// ─── FINANCE MODULE (V2 PHASE 1) ─────────────────────────────────────────────

model FinanceSettings {
  id                    String  @id @default(uuid())
  schoolId              String  @unique
  currencySymbol        String  @default("₦")
  invoicePrefix         String  @default("INV-")
  receiptPrefix         String  @default("REC-")
  allowPartialPayment   Boolean @default(true)
  allowOverpayment      Boolean @default(false)
  autoApplyWallet       Boolean @default(false)
  showOptionalFees      Boolean @default(true)
  showItemizedBreakdown Boolean @default(true)
  financeBranding       Json?
  enableTransport       Boolean @default(false)
  financeModuleToggles  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

enum FeeType {
  FEE
  ITEM
}

enum FeeCategory {
  TUITION
  EXAM
  DEVELOPMENT
  TRANSPORT
  BOOKS
  UNIFORM
  HOSTEL
  LUNCH
  ACTIVITY
  CUSTOM
}

enum StudentTypeScope {
  NEW_INTAKE
  RETURNING
  BOTH
}

enum TermScope {
  FIRST_TERM
  SECOND_TERM
  THIRD_TERM
  ANNUAL
}

enum FeeScopeChoice {
  WHOLE_SCHOOL
  SECTION
  CLASS
  STUDENTS
}

model FeeDefinition {
  id               String           @id @default(uuid())
  schoolId         String
  branchId         String?
  name             String
  code             String?
  type             FeeType          @default(FEE)
  category         FeeCategory      @default(TUITION)
  amount           Float            @default(0)
  quantity         Int?
  studentType      StudentTypeScope @default(BOTH)
  scope            FeeScopeChoice   @default(WHOLE_SCHOOL)
  classIds         String[] // specific class arm IDs when scope = CLASS
  termScope        TermScope        @default(ANNUAL)
  isCompulsory     Boolean          @default(true)
  showOnPortal     Boolean          @default(true)
  allowInstallment Boolean          @default(false)
  dueDate          DateTime?
  lateFeeRule      Json?
  discountRule     Json?
  isActive         Boolean          @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  school      School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch      Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignments StudentFeeAssignment[]
}

model StudentFeeAssignment {
  id              String   @id @default(uuid())
  schoolId        String
  studentId       String
  feeDefinitionId String
  amount          Float
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeDefinition FeeDefinition  @relation(fields: [feeDefinitionId], references: [id], onDelete: Cascade)
}

// ─── SCHOLARSHIP & DISCOUNT MANAGEMENT (Phase 2) ─────────────────────────────

enum ScholarshipType {
  SCHOLARSHIP // fully/partially sponsored
  PERCENTAGE // e.g. 50% off total fees
  FIXED_AMOUNT // specific agreed amount student pays
}

enum ScholarshipStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

model Scholarship {
  id          String            @id @default(uuid())
  schoolId    String
  studentId   String
  type        ScholarshipType
  value       Float // percentage (0-100) or fixed amount
  description String?
  sponsorName String? // for SCHOLARSHIP type
  status      ScholarshipStatus @default(ACTIVE)
  startTerm   String?
  startYear   String?
  endTerm     String?
  endYear     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  school  School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId])
  @@index([schoolId, isDeleted])
}

enum TransportBillingMode {
  TERMLY
  MONTHLY
}

model TransportRoute {
  id          String               @id @default(uuid())
  schoolId    String
  branchId    String?
  routeName   String
  pickupZone  String?
  priceOneWay Float
  priceReturn Float
  billingMode TransportBillingMode @default(TERMLY)
  isActive    Boolean              @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  school      School                       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch      Branch?                      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignments StudentTransportAssignment[]
}

model StudentTransportAssignment {
  id            String  @id @default(uuid())
  schoolId      String
  studentId     String
  routeId       String
  transportMode String // "ONE_WAY" or "RETURN"
  customPrice   Float?
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  route   TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

model StudentWallet {
  id        String  @id @default(uuid())
  schoolId  String
  branchId  String?
  studentId String  @unique
  balance   Float   @default(0)
  status    String  @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school       School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch       Branch?                    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student      StudentProfile             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions StudentWalletTransaction[]
}

enum StudentWalletTxType {
  DEPOSIT
  INVOICE_APPLICATION
  ADJUSTMENT
  CARRY_FORWARD
  OVERPAYMENT_CREDIT
}

model StudentWalletTransaction {
  id            String              @id @default(uuid())
  walletId      String
  schoolId      String
  branchId      String?
  type          StudentWalletTxType
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  reference     String              @unique
  description   String?
  auditMetadata Json?

  createdAt DateTime @default(now())

  wallet StudentWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  school School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
}

model FinanceInvoice {
  id              String        @id @default(uuid())
  schoolId        String
  branchId        String?
  studentId       String
  term            String?
  academicYear    String?
  invoiceNumber   String        @unique
  subTotal        Float         @default(0)
  discountTotal   Float         @default(0)
  taxTotal        Float         @default(0)
  walletDeduction Float         @default(0)
  totalAmount     Float
  amountPaid      Float         @default(0)
  balanceDue      Float
  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  school            School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch            Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student           StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items             FinanceInvoiceItem[]
  PaymentAllocation PaymentAllocation[]
}

model FinanceInvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  type        String // "FEE", "TRANSPORT", "ITEM", "DISCOUNT"
  referenceId String?
  label       String
  quantity    Int     @default(1)
  unitPrice   Float
  amount      Float

  createdAt DateTime @default(now())

  invoice FinanceInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ─── FINANCE MODULE (V2 PHASE 2) ─────────────────────────────────────────────

enum PaymentEnv {
  TEST
  LIVE
}

enum PaymentTxStatus {
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
  CANCELLED
  UNDER_REVIEW
  REVERSED
}

enum PaymentTxMethod {
  PAYSTACK
  REMITA
  BANK_TRANSFER
  CASH
  POS
  WALLET
  MANUAL_ADJUSTMENT
}

enum TransferSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  CLARIFICATION_NEEDED
}

model SchoolPaymentSettings {
  id                    String     @id @default(uuid())
  schoolId              String     @unique
  paystackPublicKey     String?
  paystackSecretEnc     String?
  paystackWebhookSecret String?
  paystackEnv           PaymentEnv @default(TEST)
  paystackEnabled       Boolean    @default(false)

  remitaPublicKey     String?
  remitaSecretEnc     String?
  remitaMerchantId    String?
  remitaWebhookSecret String?
  remitaEnabled       Boolean @default(false)

  merchantDisplayName      String?
  bankTransferEnabled      Boolean @default(true)
  transferEvidenceRequired Boolean @default(true)
  allowPartialPayment      Boolean @default(true)
  allowOverpayment         Boolean @default(false)
  autoApplyWallet          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model SchoolBankAccount {
  id                  String  @id @default(uuid())
  schoolId            String
  branchId            String?
  bankName            String
  accountName         String
  accountNumber       String
  accountType         String?
  notes               String?
  displayInstructions String? @db.Text
  isDefault           Boolean @default(false)
  isActive            Boolean @default(true)
  sortOrder           Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([schoolId])
}

model PaymentTransaction {
  id              String          @id @default(uuid())
  schoolId        String
  branchId        String?
  studentId       String
  reference       String          @unique
  amount          Float
  currency        String          @default("NGN")
  status          PaymentTxStatus @default(PENDING)
  method          PaymentTxMethod
  gatewayRef      String?
  gatewayResponse Json?
  paidAt          DateTime?
  reversedAt      DateTime?
  reversalReason  String?
  initiatedBy     String?
  note            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch      Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student     StudentProfile      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  allocations PaymentAllocation[]
  transfer    TransferSubmission?
  receipt     FinanceReceipt?

  @@index([schoolId, studentId])
  @@index([reference])
  @@index([status])
}

model PaymentAllocation {
  id                   String  @id @default(uuid())
  schoolId             String
  paymentTransactionId String
  invoiceId            String
  allocatedAmount      Float
  note                 String?

  createdAt DateTime @default(now())

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  transaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)
  invoice     FinanceInvoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([paymentTransactionId])
  @@index([invoiceId])
}

model TransferSubmission {
  id                   String                   @id @default(uuid())
  schoolId             String
  branchId             String?
  studentId            String
  paymentTransactionId String                   @unique
  amount               Float
  transferDate         DateTime
  senderName           String
  senderBank           String?
  transferReference    String?
  note                 String?
  evidenceUrl          String?
  evidencePublicId     String?
  status               TransferSubmissionStatus @default(PENDING)
  reviewedBy           String?
  reviewedAt           DateTime?
  reviewNote           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch      Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student     StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
}

model FinanceReceipt {
  id                    String          @id @default(uuid())
  schoolId              String
  branchId              String?
  studentId             String
  paymentTransactionId  String          @unique
  receiptNumber         String          @unique
  amountPaid            Float
  method                PaymentTxMethod
  invoiceNumbers        String[]
  walletBalanceAfter    Float?
  remainingBalanceAfter Float?
  metadata              Json?

  createdAt DateTime @default(now())

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch      Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student     StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
}

model PaystackWebhookLog {
  id             String  @id @default(uuid())
  schoolId       String?
  event          String
  reference      String?
  payload        Json
  verified       Boolean @default(false)
  processed      Boolean @default(false)
  processingNote String?

  createdAt DateTime @default(now())

  @@index([reference])
  @@index([schoolId])
}

model FinanceNotificationLog {
  id        String  @id @default(uuid())
  schoolId  String
  studentId String?
  type      String
  recipient String?
  status    String  @default("SENT")
  metadata  Json?

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

// ─── QR-BASED ATTENDANCE MODULE ──────────────────────────────────────────────

/// QR code record for a student or staff member.
/// The qrToken is a signed JWT — raw IDs are never exposed.
model QRCode {
  id        String   @id @default(uuid())
  schoolId  String
  branchId  String?
  userType  String // "student" | "staff"
  userId    String // StudentProfile.id or TeacherProfile.id
  qrToken   String   @unique // signed JWT, opaque to client
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school   School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  scanLogs AttendanceScanLog[]

  @@index([schoolId, userType, userId])
  @@index([qrToken])
}

/// Daily staff check-in / check-out record.
model StaffAttendance {
  id           String                @id @default(uuid())
  schoolId     String
  branchId     String?
  staffId      String // TeacherProfile.id
  date         String // "YYYY-MM-DD"
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       StaffAttendanceStatus @default(ABSENT)
  markedBy     String                @default("QR") // "QR" | "MANUAL" | "ADMIN_OVERRIDE"
  note         String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  staff  TeacherProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  school School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([schoolId, date])
  @@index([branchId])
}

/// Audit log for every QR scan attempt (success or failure).
model AttendanceScanLog {
  id         String   @id @default(uuid())
  schoolId   String
  qrCodeId   String?
  userId     String // userId for audit trail
  userType   String // "student" | "staff"
  scanTime   DateTime @default(now())
  deviceInfo String?
  result     String // "SUCCESS" | "DUPLICATE" | "INVALID" | "CROSS_SCHOOL" | "INACTIVE"
  reason     String?

  qrCode QRCode? @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, scanTime])
  @@index([qrCodeId])
}

/// Registered hardware/browser scanners
model ScannerDevice {
  id        String   @id @default(uuid())
  schoolId  String
  branchId  String?
  name      String
  token     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

/// Per-school attendance configuration.
model AttendanceSettings {
  id                    String   @id @default(uuid())
  schoolId              String   @unique
  schoolStartTime       String   @default("08:00")
  lateThresholdTime     String   @default("08:30")
  allowMultipleScan     Boolean  @default(false)
  qrEnabled             Boolean  @default(true)
  manualEnabled         Boolean  @default(true)
  autoCloseTime         String?  @default("17:00")
  staffCheckOutRequired Boolean  @default(true)
  timezone              String   @default("Africa/Lagos")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

enum StaffAttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
}

// ─── LEDGER (INCOME & EXPENSES) ─────────────────────────────────────────────

enum LedgerSource {
  AUTO
  MANUAL
}

enum LedgerCategoryType {
  INCOME
  EXPENSE
}

model FinanceCategory {
  id        String             @id @default(uuid())
  schoolId  String
  name      String
  type      LedgerCategoryType
  createdAt DateTime           @default(now())

  incomes  IncomeRecord[]
  expenses ExpenseRecord[]

  @@unique([schoolId, name, type])
}

model IncomeRecord {
  id          String       @id @default(uuid())
  schoolId    String
  categoryId  String
  description String
  amount      Float
  date        DateTime
  source      LedgerSource // AUTO or MANUAL
  referenceId String? // Links to PaymentTransaction if AUTO
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  category FinanceCategory @relation(fields: [categoryId], references: [id])
}

model ExpenseRecord {
  id          String       @id @default(uuid())
  schoolId    String
  categoryId  String
  description String
  amount      Float
  date        DateTime
  source      LedgerSource // AUTO or MANUAL
  referenceId String? // Links to Payroll run if AUTO
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  category FinanceCategory @relation(fields: [categoryId], references: [id])
}

// ─── PAYROLL MODULE ──────────────────────────────────────────────────────────

// Per-staff payroll earning/deduction configuration items
model PayrollSetting {
  id        String   @id @default(uuid())
  schoolId  String?
  staffId   String
  type      String // "earning" | "deduction"
  itemName  String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff TeacherProfile @relation("StaffPayrollSettings", fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId, staffId])
}

// Staff loan records
model StaffLoan {
  id                 String   @id @default(uuid())
  schoolId           String?
  staffId            String
  loanAmount         Float
  dateCollected      DateTime @default(now())
  repaymentPerMonth  Float    @default(0)
  outstandingBalance Float
  status             String   @default("active") // active | cleared
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  staff TeacherProfile @relation("StaffLoans", fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId, staffId])
}

// Pension contribution accumulation per staff
model PensionLedger {
  id           String   @id @default(uuid())
  schoolId     String?
  staffId      String
  amount       Float
  date         DateTime @default(now())
  payrollRunId String?
  createdAt    DateTime @default(now())

  staff      TeacherProfile @relation("StaffPension", fields: [staffId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun?    @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@index([schoolId, staffId])
}

// A single batch payroll run
model PayrollRun {
  id              String   @id @default(uuid())
  schoolId        String?
  runDate         DateTime @default(now())
  month           Int
  year            Int
  totalGross      Float    @default(0)
  totalDeductions Float    @default(0)
  totalNet        Float    @default(0)
  status          String   @default("draft") // draft | confirmed
  createdBy       String?
  expenseRecordId String? // Links to auto-created ExpenseRecord on confirm
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items          PayrollRunItem[]
  pensionEntries PensionLedger[]

  @@index([schoolId])
}

// Per-staff line item within a payroll run
model PayrollRunItem {
  id                  String @id @default(uuid())
  payrollRunId        String
  staffId             String
  gross               Float
  deductionsBreakdown Json // [{name, amount}]
  earningsBreakdown   Json // [{name, amount}]
  net                 Float
  paymentMethod       String @default("pending") // pending | gateway | manual | export
  status              String @default("pending") // pending | paid

  payrollRun PayrollRun     @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staff      TeacherProfile @relation("StaffPayrollRunItems", fields: [staffId], references: [id])

  @@index([payrollRunId])
  @@index([staffId])
}

model PromotionHistory {
  id          String  @id @default(uuid())
  schoolId    String
  studentId   String
  fromClassId String?
  toClassId   String?
  sessionId   String
  promotedBy  String? // ID of the user who performed the promotion
  status      String  @default("PROMOTED") // PROMOTED, HELD_BACK, GRADUATED
  notes       String?

  student   StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromClass Class?          @relation("FromClass", fields: [fromClassId], references: [id])
  toClass   Class?          @relation("ToClass", fields: [toClassId], references: [id])
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, studentId])
}

// --- PUBLIC APPLICATIONS (ADMISSION / RECRUITMENT) --------------------------

model Application {
  id              String @id @default(uuid())
  schoolId        String
  pinId           String @unique
  applicationType String // ADMISSION_APPLICATION, EMPLOYMENT
  status          String @default("PENDING") // PENDING, APPROVED, REJECTED

  interviewDate     String?
  interviewTime     String?
  interviewLocation String?

  formData Json // Stores all dynamic form inputs

  applicantName  String
  applicantEmail String?
  applicantPhone String?

  passportUrl          String?
  birthCertificateUrl  String?
  otherCertificatesUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pin    SchoolPin @relation(fields: [pinId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
